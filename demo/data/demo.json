{
  "id": "demo",
  "gruppe": "Demo — Kostprobe",
  "lektionen": [
    {
      "titel": "Sein, Werden, Haben",
      "vokabeln": [
        {
          "griechisch": "εἰμί",
          "umschrift": "eimí",
          "deutsch": "sein, existieren",
          "erklaerung": "Unregelmäßig: ἔσομαι (Fut.). Enklitisch im Präsens.",
          "sprich": "eimii",
          "audio": "data/audio/gwv1_00_00.m4a"
        },
        {
          "griechisch": "γίγνομαι",
          "umschrift": "gígnomai",
          "deutsch": "werden, entstehen, geschehen",
          "erklaerung": "Stammformen: γενήσομαι, ἐγενόμην, γέγονα",
          "sprich": "gígnomai",
          "audio": "data/audio/gwv1_00_01.m4a"
        },
        {
          "griechisch": "ἔχω",
          "umschrift": "échō",
          "deutsch": "haben, halten",
          "erklaerung": "Stammformen: ἕξω/σχήσω, ἔσχον, ἔσχηκα",
          "sprich": "échoh",
          "audio": "data/audio/gwv1_00_02.m4a"
        },
        {
          "griechisch": "ὑπάρχω",
          "umschrift": "hypárchō",
          "deutsch": "vorhanden sein, zur Verfügung stehen",
          "sprich": "hüpárchoh",
          "audio": "data/audio/gwv1_00_03.m4a"
        },
        {
          "griechisch": "πάρειμι",
          "umschrift": "páreimi",
          "deutsch": "anwesend sein, dabei sein",
          "sprich": "páreimi",
          "audio": "data/audio/gwv1_00_04.m4a"
        },
        {
          "griechisch": "ἄπειμι",
          "umschrift": "ápeimi",
          "deutsch": "abwesend sein, fort sein",
          "sprich": "ápeimi",
          "audio": "data/audio/gwv1_00_05.m4a"
        },
        {
          "griechisch": "ἔξεστι(ν)",
          "umschrift": "éxesti(n)",
          "deutsch": "es ist möglich, es ist erlaubt",
          "erklaerung": "Unpersönlich mit Dativ und Infinitiv",
          "sprich": "éxesti",
          "audio": "data/audio/gwv1_00_06.m4a"
        },
        {
          "griechisch": "δεῖ",
          "umschrift": "deî",
          "deutsch": "es ist nötig, man muss",
          "erklaerung": "Unpersönlich mit Akkusativ und Infinitiv",
          "sprich": "dei",
          "audio": "data/audio/gwv1_00_07.m4a"
        },
        {
          "griechisch": "χρή",
          "umschrift": "chrḗ",
          "deutsch": "man muss, man soll",
          "sprich": "chrä",
          "audio": "data/audio/gwv1_00_08.m4a"
        },
        {
          "griechisch": "μέλλω",
          "umschrift": "méllō",
          "deutsch": "im Begriff sein, zögern; sollen",
          "erklaerung": "Mit Infinitiv Futur: beabsichtigen",
          "sprich": "mélloh",
          "audio": "data/audio/gwv1_00_09.m4a"
        },
        {
          "griechisch": "τυγχάνω",
          "umschrift": "tynchánō",
          "deutsch": "zufällig sein, erlangen, treffen",
          "erklaerung": "τυγχάνω + Partizip: gerade etwas tun",
          "sprich": "tünchánoh",
          "audio": "data/audio/gwv1_00_10.m4a"
        },
        {
          "griechisch": "φύω",
          "umschrift": "phýō",
          "deutsch": "hervorbringen; (Perf.) von Natur sein",
          "erklaerung": "πέφυκα: von Natur aus beschaffen sein",
          "sprich": "füoh",
          "audio": "data/audio/gwv1_00_11.m4a"
        },
        {
          "griechisch": "κεῖμαι",
          "umschrift": "keîmai",
          "deutsch": "liegen, daliegen, festgesetzt sein",
          "sprich": "keimai",
          "audio": "data/audio/gwv1_00_12.m4a"
        },
        {
          "griechisch": "ἵσταμαι",
          "umschrift": "hístamai",
          "deutsch": "sich stellen, stehen",
          "erklaerung": "Medium von ἵστημι; ἕστηκα: ich stehe",
          "sprich": "hístamai",
          "audio": "data/audio/gwv1_00_13.m4a"
        },
        {
          "griechisch": "κάθημαι",
          "umschrift": "káthēmai",
          "deutsch": "sitzen",
          "sprich": "kátähmai",
          "audio": "data/audio/gwv1_00_14.m4a"
        },
        {
          "griechisch": "οἰκέω",
          "umschrift": "oikéō",
          "deutsch": "wohnen, bewohnen, verwalten",
          "sprich": "oikéoh",
          "audio": "data/audio/gwv1_00_15.m4a"
        },
        {
          "griechisch": "ζάω",
          "umschrift": "záō",
          "deutsch": "leben",
          "erklaerung": "Kontrahiert: ζῶ, ζῇς, ζῇ",
          "sprich": "záoh",
          "audio": "data/audio/gwv1_00_16.m4a"
        },
        {
          "griechisch": "βιόω",
          "umschrift": "bióō",
          "deutsch": "das Leben verbringen, leben",
          "sprich": "bióoh",
          "audio": "data/audio/gwv1_00_17.m4a"
        },
        {
          "griechisch": "ἀποθνῄσκω",
          "umschrift": "apothnḗiskō",
          "deutsch": "sterben",
          "erklaerung": "Stammformen: ἀποθανοῦμαι, ἀπέθανον, τέθνηκα",
          "sprich": "apotnähiskoh",
          "audio": "data/audio/gwv1_00_18.m4a"
        },
        {
          "griechisch": "τελευτάω",
          "umschrift": "teleutáō",
          "deutsch": "beenden; sterben",
          "sprich": "teleutáoh",
          "audio": "data/audio/gwv1_00_19.m4a"
        }
      ]
    },
    {
      "titel": "Der Mensch",
      "vokabeln": [
        {
          "griechisch": "ὁ ἄνθρωπος, τοῦ ἀνθρώπου",
          "umschrift": "ánthrōpos",
          "deutsch": "Mensch",
          "sprich": "ho ántrohpos, tuh antróhpu",
          "audio": "data/audio/gwm_00_00.m4a",
          "flexAudio": [
            "data/audio/gwm_00_00_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ ἀνήρ, τοῦ ἀνδρός",
          "umschrift": "anḗr",
          "deutsch": "Mann, Ehemann",
          "erklaerung": "Dativ Plural: ἀνδράσι(ν)",
          "sprich": "ho anähr, tuh andrós",
          "audio": "data/audio/gwm_00_01.m4a",
          "flexAudio": [
            "data/audio/gwm_00_01_f1.m4a"
          ]
        },
        {
          "griechisch": "ἡ γυνή, τῆς γυναικός",
          "umschrift": "gynḗ",
          "deutsch": "Frau, Ehefrau",
          "sprich": "hä günä, tähs günaikós",
          "audio": "data/audio/gwm_00_02.m4a",
          "flexAudio": [
            "data/audio/gwm_00_02_f1.m4a"
          ]
        },
        {
          "griechisch": "τὸ τέκνον, τοῦ τέκνου",
          "umschrift": "téknon",
          "deutsch": "Kind",
          "sprich": "to téknon, tuh téknu",
          "audio": "data/audio/gwm_00_03.m4a",
          "flexAudio": [
            "data/audio/gwm_00_03_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ παῖς, τοῦ παιδός",
          "umschrift": "paîs",
          "deutsch": "Kind, Knabe; Sklave",
          "sprich": "ho pais, tuh paidós",
          "audio": "data/audio/gwm_00_04.m4a",
          "flexAudio": [
            "data/audio/gwm_00_04_f1.m4a"
          ]
        },
        {
          "griechisch": "τὸ παιδίον, τοῦ παιδίου",
          "umschrift": "paidíon",
          "deutsch": "kleines Kind",
          "sprich": "to paidíon, tuh paidíu",
          "audio": "data/audio/gwm_00_05.m4a",
          "flexAudio": [
            "data/audio/gwm_00_05_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ νεανίας, τοῦ νεανίου",
          "umschrift": "neanías",
          "deutsch": "junger Mann, Jüngling",
          "sprich": "ho neanías, tuh neaníu",
          "audio": "data/audio/gwm_00_06.m4a",
          "flexAudio": [
            "data/audio/gwm_00_06_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ γέρων, τοῦ γέροντος",
          "umschrift": "gérōn",
          "deutsch": "Greis, alter Mann",
          "sprich": "ho gérohn, tuh gérontos",
          "audio": "data/audio/gwm_00_07.m4a",
          "flexAudio": [
            "data/audio/gwm_00_07_f1.m4a"
          ]
        },
        {
          "griechisch": "ἡ παρθένος, τῆς παρθένου",
          "umschrift": "parthénos",
          "deutsch": "Jungfrau, Mädchen",
          "sprich": "hä parténos, tähs parténu",
          "audio": "data/audio/gwm_00_08.m4a",
          "flexAudio": [
            "data/audio/gwm_00_08_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ θνητός",
          "umschrift": "thnētós",
          "deutsch": "der Sterbliche",
          "erklaerung": "Adjektiv θνητός: sterblich",
          "sprich": "ho tnähtós",
          "audio": "data/audio/gwm_00_09.m4a"
        },
        {
          "griechisch": "ὁ βροτός, τοῦ βροτοῦ",
          "umschrift": "brotós",
          "deutsch": "der Sterbliche (poet.)",
          "sprich": "ho brotós, tuh brotuh",
          "audio": "data/audio/gwm_00_10.m4a",
          "flexAudio": [
            "data/audio/gwm_00_10_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ φίλος, τοῦ φίλου",
          "umschrift": "phílos",
          "deutsch": "Freund",
          "sprich": "ho fílos, tuh fílu",
          "audio": "data/audio/gwm_00_11.m4a",
          "flexAudio": [
            "data/audio/gwm_00_11_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ ἑταῖρος, τοῦ ἑταίρου",
          "umschrift": "hetaîros",
          "deutsch": "Gefährte, Kamerad",
          "sprich": "ho hetairos, tuh hetairu",
          "audio": "data/audio/gwm_00_12.m4a",
          "flexAudio": [
            "data/audio/gwm_00_12_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ ἐχθρός, τοῦ ἐχθροῦ",
          "umschrift": "echthrós",
          "deutsch": "Feind (persönlich)",
          "sprich": "ho echtrós, tuh echtruh",
          "audio": "data/audio/gwm_00_13.m4a",
          "flexAudio": [
            "data/audio/gwm_00_13_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ ξένος, τοῦ ξένου",
          "umschrift": "xénos",
          "deutsch": "Fremder, Gastfreund",
          "sprich": "ho xénos, tuh xénu",
          "audio": "data/audio/gwm_00_14.m4a",
          "flexAudio": [
            "data/audio/gwm_00_14_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ πολίτης, τοῦ πολίτου",
          "umschrift": "polítēs",
          "deutsch": "Bürger",
          "sprich": "ho polítähs, tuh polítu",
          "audio": "data/audio/gwm_00_15.m4a",
          "flexAudio": [
            "data/audio/gwm_00_15_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ δοῦλος, τοῦ δούλου",
          "umschrift": "doûlos",
          "deutsch": "Sklave",
          "sprich": "ho duhlos, tuh dúlu",
          "audio": "data/audio/gwm_00_16.m4a",
          "flexAudio": [
            "data/audio/gwm_00_16_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ δεσπότης, τοῦ δεσπότου",
          "umschrift": "despótēs",
          "deutsch": "Herr, Gebieter",
          "sprich": "ho despótähs, tuh despótu",
          "audio": "data/audio/gwm_00_17.m4a",
          "flexAudio": [
            "data/audio/gwm_00_17_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ οἰκέτης, τοῦ οἰκέτου",
          "umschrift": "oikétēs",
          "deutsch": "Haussklave, Diener",
          "sprich": "ho oikétähs, tuh oikétu",
          "audio": "data/audio/gwm_00_18.m4a",
          "flexAudio": [
            "data/audio/gwm_00_18_f1.m4a"
          ]
        },
        {
          "griechisch": "τὸ ὄνομα, τοῦ ὀνόματος",
          "umschrift": "ónoma",
          "deutsch": "Name",
          "sprich": "to ónoma, tuh onómatos",
          "audio": "data/audio/gwm_00_19.m4a",
          "flexAudio": [
            "data/audio/gwm_00_19_f1.m4a"
          ]
        }
      ]
    },
    {
      "titel": "Die olympischen Götter",
      "vokabeln": [
        {
          "griechisch": "ὁ Ζεύς, τοῦ Διός",
          "umschrift": "Zeús",
          "deutsch": "Zeus",
          "erklaerung": "Akk. Δία, Dat. Διί",
          "sprich": "ho Zeus, tuh Diós",
          "audio": "data/audio/gwg_01_00.m4a",
          "flexAudio": [
            "data/audio/gwg_01_00_f1.m4a"
          ]
        },
        {
          "griechisch": "ἡ Ἥρα, τῆς Ἥρας",
          "umschrift": "Hḗra",
          "deutsch": "Hera",
          "sprich": "hä Hähra, tähs Hähras",
          "audio": "data/audio/gwg_01_01.m4a",
          "flexAudio": [
            "data/audio/gwg_01_01_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ Ποσειδῶν, τοῦ Ποσειδῶνος",
          "umschrift": "Poseidôn",
          "deutsch": "Poseidon",
          "sprich": "ho Poseidohn, tuh Poseidohnos",
          "audio": "data/audio/gwg_01_02.m4a",
          "flexAudio": [
            "data/audio/gwg_01_02_f1.m4a"
          ]
        },
        {
          "griechisch": "ἡ Ἀθηνᾶ, τῆς Ἀθηνᾶς",
          "umschrift": "Athēnâ",
          "deutsch": "Athena",
          "sprich": "hä Atähnah, tähs Atähnahs",
          "audio": "data/audio/gwg_01_03.m4a",
          "flexAudio": [
            "data/audio/gwg_01_03_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ Ἀπόλλων, τοῦ Ἀπόλλωνος",
          "umschrift": "Apóllōn",
          "deutsch": "Apollon",
          "sprich": "ho Apóllohn, tuh Apóllohnos",
          "audio": "data/audio/gwg_01_04.m4a",
          "flexAudio": [
            "data/audio/gwg_01_04_f1.m4a"
          ]
        },
        {
          "griechisch": "ἡ Ἄρτεμις, τῆς Ἀρτέμιδος",
          "umschrift": "Ártemis",
          "deutsch": "Artemis",
          "sprich": "hä Ártemis, tähs Artémidos",
          "audio": "data/audio/gwg_01_05.m4a",
          "flexAudio": [
            "data/audio/gwg_01_05_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ Ἑρμῆς, τοῦ Ἑρμοῦ",
          "umschrift": "Hermês",
          "deutsch": "Hermes",
          "sprich": "ho Hermähs, tuh Hermuh",
          "audio": "data/audio/gwg_01_06.m4a",
          "flexAudio": [
            "data/audio/gwg_01_06_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ Ἄρης, τοῦ Ἄρεως",
          "umschrift": "Árēs",
          "deutsch": "Ares",
          "sprich": "ho Árähs, tuh Áreohs",
          "audio": "data/audio/gwg_01_07.m4a",
          "flexAudio": [
            "data/audio/gwg_01_07_f1.m4a"
          ]
        },
        {
          "griechisch": "ἡ Ἀφροδίτη, τῆς Ἀφροδίτης",
          "umschrift": "Aphrodítē",
          "deutsch": "Aphrodite",
          "sprich": "hä Afrodítä, tähs Afrodítähs",
          "audio": "data/audio/gwg_01_08.m4a",
          "flexAudio": [
            "data/audio/gwg_01_08_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ Ἥφαιστος, τοῦ Ἡφαίστου",
          "umschrift": "Hḗphaistos",
          "deutsch": "Hephaistos",
          "sprich": "ho Hähfaistos, tuh Hähfaistu",
          "audio": "data/audio/gwg_01_09.m4a",
          "flexAudio": [
            "data/audio/gwg_01_09_f1.m4a"
          ]
        },
        {
          "griechisch": "ἡ Δημήτηρ, τῆς Δήμητρος",
          "umschrift": "Dēmḗtēr",
          "deutsch": "Demeter",
          "sprich": "hä Dähmähtähr, tähs Dähmähtros",
          "audio": "data/audio/gwg_01_10.m4a",
          "flexAudio": [
            "data/audio/gwg_01_10_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ Διόνυσος, τοῦ Διονύσου",
          "umschrift": "Diónysos",
          "deutsch": "Dionysos",
          "sprich": "ho Diónüsos, tuh Dionüsu",
          "audio": "data/audio/gwg_01_11.m4a",
          "flexAudio": [
            "data/audio/gwg_01_11_f1.m4a"
          ]
        },
        {
          "griechisch": "ἡ Ἑστία, τῆς Ἑστίας",
          "umschrift": "Hestía",
          "deutsch": "Hestia",
          "sprich": "hä Hestía, tähs Hestías",
          "audio": "data/audio/gwg_01_12.m4a",
          "flexAudio": [
            "data/audio/gwg_01_12_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ Ἅιδης, τοῦ Ἅιδου",
          "umschrift": "Háidēs",
          "deutsch": "Hades, Unterwelt",
          "erklaerung": "ἐν Ἅιδου: in der Unterwelt",
          "sprich": "ho Hahdähs, tuh Hahdu",
          "audio": "data/audio/gwg_01_13.m4a",
          "flexAudio": [
            "data/audio/gwg_01_13_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ Ὄλυμπος, τοῦ Ὀλύμπου",
          "umschrift": "Ólympos",
          "deutsch": "Olymp",
          "sprich": "ho Ólümpos, tuh Olümpu",
          "audio": "data/audio/gwg_01_14.m4a",
          "flexAudio": [
            "data/audio/gwg_01_14_f1.m4a"
          ]
        },
        {
          "griechisch": "ἡ Μοῦσα, τῆς Μούσης",
          "umschrift": "Moûsa",
          "deutsch": "Muse",
          "sprich": "hä Muhsa, tähs Músähs",
          "audio": "data/audio/gwg_01_15.m4a",
          "flexAudio": [
            "data/audio/gwg_01_15_f1.m4a"
          ]
        },
        {
          "griechisch": "ἡ νύμφη, τῆς νύμφης",
          "umschrift": "nýmphē",
          "deutsch": "Nymphe",
          "sprich": "hä nümfä, tähs nümfähs",
          "audio": "data/audio/gwg_01_16.m4a",
          "flexAudio": [
            "data/audio/gwg_01_16_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ Τιτάν, τοῦ Τιτᾶνος",
          "umschrift": "Titán",
          "deutsch": "Titan",
          "sprich": "ho Titán, tuh Titahnos",
          "audio": "data/audio/gwg_01_17.m4a",
          "flexAudio": [
            "data/audio/gwg_01_17_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ Προμηθεύς, τοῦ Προμηθέως",
          "umschrift": "Promētheús",
          "deutsch": "Prometheus",
          "sprich": "ho Promähteus, tuh Promähtéohs",
          "audio": "data/audio/gwg_01_18.m4a",
          "flexAudio": [
            "data/audio/gwg_01_18_f1.m4a"
          ]
        },
        {
          "griechisch": "ὁ Ἡρακλῆς, τοῦ Ἡρακλέους",
          "umschrift": "Hēraklês",
          "deutsch": "Herakles",
          "sprich": "ho Hähraklähs, tuh Hährakléus",
          "audio": "data/audio/gwg_01_19.m4a",
          "flexAudio": [
            "data/audio/gwg_01_19_f1.m4a"
          ]
        }
      ]
    }
  ]
}
