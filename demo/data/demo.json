{"id": "demo", "gruppe": "Demo — Kostprobe", "lektionen": [{"titel": "Sein, Werden, Haben", "vokabeln": [{"griechisch": "εἰμί", "umschrift": "eimí", "deutsch": "sein, existieren", "erklaerung": "Unregelmäßig: ἔσομαι (Fut.). Enklitisch im Präsens.", "sprich": "ehmii", "audio": "data/audio/gwv1_00_00.m4a"}, {"griechisch": "γίγνομαι", "umschrift": "gígnomai", "deutsch": "werden, entstehen, geschehen", "erklaerung": "Stammformen: γενήσομαι, ἐγενόμην, γέγονα", "sprich": "gígnomai", "audio": "data/audio/gwv1_00_01.m4a"}, {"griechisch": "ἔχω", "umschrift": "échō", "deutsch": "haben, halten", "erklaerung": "Stammformen: ἕξω/σχήσω, ἔσχον, ἔσχηκα", "sprich": "ékoh", "audio": "data/audio/gwv1_00_02.m4a"}, {"griechisch": "ὑπάρχω", "umschrift": "hypárchō", "deutsch": "vorhanden sein, zur Verfügung stehen", "sprich": "hüpárkoh", "audio": "data/audio/gwv1_00_03.m4a"}, {"griechisch": "πάρειμι", "umschrift": "páreimi", "deutsch": "anwesend sein, dabei sein", "sprich": "párehmi", "audio": "data/audio/gwv1_00_04.m4a"}, {"griechisch": "ἄπειμι", "umschrift": "ápeimi", "deutsch": "abwesend sein, fort sein", "sprich": "ápehmi", "audio": "data/audio/gwv1_00_05.m4a"}, {"griechisch": "ἔξεστι(ν)", "umschrift": "éxesti(n)", "deutsch": "es ist möglich, es ist erlaubt", "erklaerung": "Unpersönlich mit Dativ und Infinitiv", "sprich": "éxesti(n)", "audio": "data/audio/gwv1_00_06.m4a"}, {"griechisch": "δεῖ", "umschrift": "deî", "deutsch": "es ist nötig, man muss", "erklaerung": "Unpersönlich mit Akkusativ und Infinitiv", "sprich": "deh", "audio": "data/audio/gwv1_00_07.m4a"}, {"griechisch": "χρή", "umschrift": "chrḗ", "deutsch": "man muss, man soll", "sprich": "krä", "audio": "data/audio/gwv1_00_08.m4a"}, {"griechisch": "μέλλω", "umschrift": "méllō", "deutsch": "im Begriff sein, zögern; sollen", "erklaerung": "Mit Infinitiv Futur: beabsichtigen", "sprich": "mélloh", "audio": "data/audio/gwv1_00_09.m4a"}, {"griechisch": "τυγχάνω", "umschrift": "tynchánō", "deutsch": "zufällig sein, erlangen, treffen", "erklaerung": "τυγχάνω + Partizip: gerade etwas tun", "sprich": "tünkánoh", "audio": "data/audio/gwv1_00_10.m4a"}, {"griechisch": "φύω", "umschrift": "phýō", "deutsch": "hervorbringen; (Perf.) von Natur sein", "erklaerung": "πέφυκα: von Natur aus beschaffen sein", "sprich": "püoh", "audio": "data/audio/gwv1_00_11.m4a"}, {"griechisch": "κεῖμαι", "umschrift": "keîmai", "deutsch": "liegen, daliegen, festgesetzt sein", "sprich": "kehmai", "audio": "data/audio/gwv1_00_12.m4a"}, {"griechisch": "ἵσταμαι", "umschrift": "hístamai", "deutsch": "sich stellen, stehen", "erklaerung": "Medium von ἵστημι; ἕστηκα: ich stehe", "sprich": "hístamai", "audio": "data/audio/gwv1_00_13.m4a"}, {"griechisch": "κάθημαι", "umschrift": "káthēmai", "deutsch": "sitzen", "sprich": "kátähmai", "audio": "data/audio/gwv1_00_14.m4a"}, {"griechisch": "οἰκέω", "umschrift": "oikéō", "deutsch": "wohnen, bewohnen, verwalten", "sprich": "ohikéoh", "audio": "data/audio/gwv1_00_15.m4a"}, {"griechisch": "ζάω", "umschrift": "záō", "deutsch": "leben", "erklaerung": "Kontrahiert: ζῶ, ζῇς, ζῇ", "sprich": "záoh", "audio": "data/audio/gwv1_00_16.m4a"}, {"griechisch": "βιόω", "umschrift": "bióō", "deutsch": "das Leben verbringen, leben", "sprich": "bióoh", "audio": "data/audio/gwv1_00_17.m4a"}, {"griechisch": "ἀποθνῄσκω", "umschrift": "apothnḗiskō", "deutsch": "sterben", "erklaerung": "Stammformen: ἀποθανοῦμαι, ἀπέθανον, τέθνηκα", "sprich": "apotnähiskoh", "audio": "data/audio/gwv1_00_18.m4a"}, {"griechisch": "τελευτάω", "umschrift": "teleutáō", "deutsch": "beenden; sterben", "sprich": "telehutáoh", "audio": "data/audio/gwv1_00_19.m4a"}]}, {"titel": "Der Mensch", "vokabeln": [{"griechisch": "ὁ ἄνθρωπος, τοῦ ἀνθρώπου", "umschrift": "ánthrōpos", "deutsch": "Mensch", "sprich": "ántrohpos", "audio": "data/audio/gwm_00_00.m4a"}, {"griechisch": "ὁ ἀνήρ, τοῦ ἀνδρός", "umschrift": "anḗr", "deutsch": "Mann, Ehemann", "erklaerung": "Dativ Plural: ἀνδράσι(ν)", "sprich": "anähr", "audio": "data/audio/gwm_00_01.m4a"}, {"griechisch": "ἡ γυνή, τῆς γυναικός", "umschrift": "gynḗ", "deutsch": "Frau, Ehefrau", "sprich": "günä", "audio": "data/audio/gwm_00_02.m4a"}, {"griechisch": "τὸ τέκνον, τοῦ τέκνου", "umschrift": "téknon", "deutsch": "Kind", "sprich": "téknon", "audio": "data/audio/gwm_00_03.m4a"}, {"griechisch": "ὁ παῖς, τοῦ παιδός", "umschrift": "paîs", "deutsch": "Kind, Knabe; Sklave", "sprich": "paîs", "audio": "data/audio/gwm_00_04.m4a"}, {"griechisch": "τὸ παιδίον, τοῦ παιδίου", "umschrift": "paidíon", "deutsch": "kleines Kind", "sprich": "paidíon", "audio": "data/audio/gwm_00_05.m4a"}, {"griechisch": "ὁ νεανίας, τοῦ νεανίου", "umschrift": "neanías", "deutsch": "junger Mann, Jüngling", "sprich": "neanías", "audio": "data/audio/gwm_00_06.m4a"}, {"griechisch": "ὁ γέρων, τοῦ γέροντος", "umschrift": "gérōn", "deutsch": "Greis, alter Mann", "sprich": "gérohn", "audio": "data/audio/gwm_00_07.m4a"}, {"griechisch": "ἡ παρθένος, τῆς παρθένου", "umschrift": "parthénos", "deutsch": "Jungfrau, Mädchen", "sprich": "parténos", "audio": "data/audio/gwm_00_08.m4a"}, {"griechisch": "ὁ θνητός", "umschrift": "thnētós", "deutsch": "der Sterbliche", "erklaerung": "Adjektiv θνητός: sterblich", "sprich": "tnähtós", "audio": "data/audio/gwm_00_09.m4a"}, {"griechisch": "ὁ βροτός, τοῦ βροτοῦ", "umschrift": "brotós", "deutsch": "der Sterbliche (poet.)", "sprich": "brotós", "audio": "data/audio/gwm_00_10.m4a"}, {"griechisch": "ὁ φίλος, τοῦ φίλου", "umschrift": "phílos", "deutsch": "Freund", "sprich": "pílos", "audio": "data/audio/gwm_00_11.m4a"}, {"griechisch": "ὁ ἑταῖρος, τοῦ ἑταίρου", "umschrift": "hetaîros", "deutsch": "Gefährte, Kamerad", "sprich": "hetaîros", "audio": "data/audio/gwm_00_12.m4a"}, {"griechisch": "ὁ ἐχθρός, τοῦ ἐχθροῦ", "umschrift": "echthrós", "deutsch": "Feind (persönlich)", "sprich": "ektrós", "audio": "data/audio/gwm_00_13.m4a"}, {"griechisch": "ὁ ξένος, τοῦ ξένου", "umschrift": "xénos", "deutsch": "Fremder, Gastfreund", "sprich": "xénos", "audio": "data/audio/gwm_00_14.m4a"}, {"griechisch": "ὁ πολίτης, τοῦ πολίτου", "umschrift": "polítēs", "deutsch": "Bürger", "sprich": "polítähs", "audio": "data/audio/gwm_00_15.m4a"}, {"griechisch": "ὁ δοῦλος, τοῦ δούλου", "umschrift": "doûlos", "deutsch": "Sklave", "sprich": "duhlos", "audio": "data/audio/gwm_00_16.m4a"}, {"griechisch": "ὁ δεσπότης, τοῦ δεσπότου", "umschrift": "despótēs", "deutsch": "Herr, Gebieter", "sprich": "despótähs", "audio": "data/audio/gwm_00_17.m4a"}, {"griechisch": "ὁ οἰκέτης, τοῦ οἰκέτου", "umschrift": "oikétēs", "deutsch": "Haussklave, Diener", "sprich": "ohikétähs", "audio": "data/audio/gwm_00_18.m4a"}, {"griechisch": "τὸ ὄνομα, τοῦ ὀνόματος", "umschrift": "ónoma", "deutsch": "Name", "sprich": "ónoma", "audio": "data/audio/gwm_00_19.m4a"}]}, {"titel": "Die olympischen Götter", "vokabeln": [{"griechisch": "ὁ Ζεύς, τοῦ Διός", "umschrift": "Zeús", "deutsch": "Zeus", "erklaerung": "Akk. Δία, Dat. Διί", "sprich": "Zehus", "audio": "data/audio/gwg_01_00.m4a"}, {"griechisch": "ἡ Ἥρα, τῆς Ἥρας", "umschrift": "Hḗra", "deutsch": "Hera", "sprich": "Hähra", "audio": "data/audio/gwg_01_01.m4a"}, {"griechisch": "ὁ Ποσειδῶν, τοῦ Ποσειδῶνος", "umschrift": "Poseidôn", "deutsch": "Poseidon", "sprich": "Posehdôn", "audio": "data/audio/gwg_01_02.m4a"}, {"griechisch": "ἡ Ἀθηνᾶ, τῆς Ἀθηνᾶς", "umschrift": "Athēnâ", "deutsch": "Athena", "sprich": "Atähnâ", "audio": "data/audio/gwg_01_03.m4a"}, {"griechisch": "ὁ Ἀπόλλων, τοῦ Ἀπόλλωνος", "umschrift": "Apóllōn", "deutsch": "Apollon", "sprich": "Apóllohn", "audio": "data/audio/gwg_01_04.m4a"}, {"griechisch": "ἡ Ἄρτεμις, τῆς Ἀρτέμιδος", "umschrift": "Ártemis", "deutsch": "Artemis", "sprich": "Ártemis", "audio": "data/audio/gwg_01_05.m4a"}, {"griechisch": "ὁ Ἑρμῆς, τοῦ Ἑρμοῦ", "umschrift": "Hermês", "deutsch": "Hermes", "sprich": "Hermês", "audio": "data/audio/gwg_01_06.m4a"}, {"griechisch": "ὁ Ἄρης, τοῦ Ἄρεως", "umschrift": "Árēs", "deutsch": "Ares", "sprich": "Árähs", "audio": "data/audio/gwg_01_07.m4a"}, {"griechisch": "ἡ Ἀφροδίτη, τῆς Ἀφροδίτης", "umschrift": "Aphrodítē", "deutsch": "Aphrodite", "sprich": "Aprodítä", "audio": "data/audio/gwg_01_08.m4a"}, {"griechisch": "ὁ Ἥφαιστος, τοῦ Ἡφαίστου", "umschrift": "Hḗphaistos", "deutsch": "Hephaistos", "sprich": "Hähpaistos", "audio": "data/audio/gwg_01_09.m4a"}, {"griechisch": "ἡ Δημήτηρ, τῆς Δήμητρος", "umschrift": "Dēmḗtēr", "deutsch": "Demeter", "sprich": "Dähmähtähr", "audio": "data/audio/gwg_01_10.m4a"}, {"griechisch": "ὁ Διόνυσος, τοῦ Διονύσου", "umschrift": "Diónysos", "deutsch": "Dionysos", "sprich": "Diónüsos", "audio": "data/audio/gwg_01_11.m4a"}, {"griechisch": "ἡ Ἑστία, τῆς Ἑστίας", "umschrift": "Hestía", "deutsch": "Hestia", "sprich": "Hestía", "audio": "data/audio/gwg_01_12.m4a"}, {"griechisch": "ὁ Ἅιδης, τοῦ Ἅιδου", "umschrift": "Háidēs", "deutsch": "Hades, Unterwelt", "erklaerung": "ἐν Ἅιδου: in der Unterwelt", "sprich": "Háidähs", "audio": "data/audio/gwg_01_13.m4a"}, {"griechisch": "ὁ Ὄλυμπος, τοῦ Ὀλύμπου", "umschrift": "Ólympos", "deutsch": "Olymp", "sprich": "Ólümpos", "audio": "data/audio/gwg_01_14.m4a"}, {"griechisch": "ἡ Μοῦσα, τῆς Μούσης", "umschrift": "Moûsa", "deutsch": "Muse", "sprich": "Muhsa", "audio": "data/audio/gwg_01_15.m4a"}, {"griechisch": "ἡ νύμφη, τῆς νύμφης", "umschrift": "nýmphē", "deutsch": "Nymphe", "sprich": "nümpä", "audio": "data/audio/gwg_01_16.m4a"}, {"griechisch": "ὁ Τιτάν, τοῦ Τιτᾶνος", "umschrift": "Titán", "deutsch": "Titan", "sprich": "Titán", "audio": "data/audio/gwg_01_17.m4a"}, {"griechisch": "ὁ Προμηθεύς, τοῦ Προμηθέως", "umschrift": "Promētheús", "deutsch": "Prometheus", "sprich": "Promähtehus", "audio": "data/audio/gwg_01_18.m4a"}, {"griechisch": "ὁ Ἡρακλῆς, τοῦ Ἡρακλέους", "umschrift": "Hēraklês", "deutsch": "Herakles", "sprich": "Hähraklês", "audio": "data/audio/gwg_01_19.m4a"}]}]}