          "umschrift": "ho noûs",
          "deutsch": "Geist, Verstand, Sinn",
          "sprich": "ho nuhs",
          "audio": "data/audio/erw1_01_23.m4a"
        },
        {
          "griechisch": "ἄριστος",
          "umschrift": "áristos",
          "deutsch": "der beste, tüchtigste",
          "sprich": "áristos",
          "audio": "data/audio/erw1_01_24.m4a"
        },
        {
          "griechisch": "ὁ λαός",
          "umschrift": "ho laós",
          "deutsch": "Volk, Kriegsvolk, Leute",
          "sprich": "ho laós",
          "audio": "data/audio/erw1_01_25.m4a"
        },
        {
          "griechisch": "τὸ ὅπλον",
          "umschrift": "to hóplon",
          "deutsch": "Waffe, Gerät; Pl. Waffen, Rüstung",
          "sprich": "to hóplon",
          "audio": "data/audio/erw1_01_26.m4a"
        },
        {
          "griechisch": "ἀφαιρέω",
          "umschrift": "aphairéō",
          "deutsch": "wegnehmen, entziehen",
          "sprich": "afairéoh",
          "audio": "data/audio/erw1_01_27.m4a"
        },
        {
          "griechisch": "ἐλάσσων",
          "umschrift": "elássōn",
          "deutsch": "kleiner, geringer, weniger",
          "sprich": "elássohn",
          "audio": "data/audio/erw1_01_28.m4a"
        },
        {
          "griechisch": "πλήν",
          "umschrift": "plḗn",
          "deutsch": "außer, ausgenommen; jedoch",
          "sprich": "plähn",
          "audio": "data/audio/erw1_01_29.m4a"
        },
        {
          "griechisch": "προσήκω",
          "umschrift": "prosḗkō",
          "deutsch": "zukommen, sich gehören; verwandt sein",
          "sprich": "prosähkoh",
          "audio": "data/audio/erw1_01_30.m4a"
        },
        {
          "griechisch": "οὐκοῦν",
          "umschrift": "oukoûn",
          "deutsch": "also, folglich, demnach",
          "sprich": "ukuhn",
          "audio": "data/audio/erw1_01_31.m4a"
        },
        {
          "griechisch": "τὸ μέγεθος",
          "umschrift": "to mégethos",
          "deutsch": "Größe, Ausmaß",
          "sprich": "to mégetos",
          "audio": "data/audio/erw1_01_32.m4a"
        },
        {
          "griechisch": "τὸ στάδιον",
          "umschrift": "to stádion",
          "deutsch": "Stadion (Längenmaß; Rennbahn)",
          "sprich": "to ßtádion",
          "audio": "data/audio/erw1_01_33.m4a"
        },
        {
          "griechisch": "γοῦν",
          "umschrift": "goûn",
          "deutsch": "jedenfalls, wenigstens, freilich",
          "sprich": "guhn",
          "audio": "data/audio/erw1_01_34.m4a"
        },
        {
          "griechisch": "διό",
          "umschrift": "dió",
          "deutsch": "deshalb, daher, weswegen",
          "sprich": "dió",
          "audio": "data/audio/erw1_01_35.m4a"
        },
        {
          "griechisch": "μιμνῄσκω",
          "umschrift": "mimnḗiskō",
          "deutsch": "erinnern; (Med.) sich erinnern (+Gen.)",
          "sprich": "mimnähiskoh",
          "audio": "data/audio/erw1_01_36.m4a"
        },
        {
          "griechisch": "θνῄσκω",
          "umschrift": "thnḗiskō",
          "deutsch": "sterben",
          "sprich": "tnähiskoh",
          "audio": "data/audio/erw1_01_37.m4a"
        },
        {
          "griechisch": "ὅσπερ",
          "umschrift": "hósper",
          "deutsch": "welcher gerade, eben der, der",
          "sprich": "hósper",
          "audio": "data/audio/erw1_01_38.m4a"
        },
        {
          "griechisch": "ἔνθα",
          "umschrift": "éntha",
          "deutsch": "dort, da; wohin, wo",
          "sprich": "énta",
          "audio": "data/audio/erw1_01_39.m4a"
        },
        {
          "griechisch": "πλείων",
          "umschrift": "pleíōn",
          "deutsch": "mehr, größer (Komp. zu πολύς)",
          "sprich": "pleiohn",
          "audio": "data/audio/erw1_01_40.m4a"
        },
        {
          "griechisch": "δείδω",
          "umschrift": "deídō",
          "deutsch": "fürchten, sich fürchten",
          "sprich": "deidoh",
          "audio": "data/audio/erw1_01_41.m4a"
        },
        {
