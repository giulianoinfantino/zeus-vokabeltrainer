          "umschrift": "ho hēgemṓn",
          "deutsch": "Anführer, Führer",
          "sprich": "ho hähgemóhn",
          "audio": "data/audio/erw1_01_43.m4a"
        },
        {
          "griechisch": "ὁ κύκλος",
          "umschrift": "ho kýklos",
          "deutsch": "Kreis, Ring, Rad",
          "sprich": "ho küklos",
          "audio": "data/audio/erw1_01_44.m4a"
        },
        {
          "griechisch": "ἄλλως",
          "umschrift": "állōs",
          "deutsch": "anders, auf andere Weise; vergeblich",
          "sprich": "állohs",
          "audio": "data/audio/erw1_01_45.m4a"
        },
        {
          "griechisch": "ἀφίστημι",
          "umschrift": "aphístēmi",
          "deutsch": "entfernen, abbringen; (intr.) abfallen",
          "sprich": "afístähmi",
          "audio": "data/audio/erw1_01_46.m4a"
        },
        {
          "griechisch": "πότερος",
          "umschrift": "póteros",
          "deutsch": "wer/welcher von beiden?",
          "sprich": "póteros",
          "audio": "data/audio/erw1_01_47.m4a"
        },
        {
          "griechisch": "τέσσαρες",
          "umschrift": "téssares",
          "deutsch": "vier",
          "sprich": "téssares",
          "audio": "data/audio/erw1_01_48.m4a"
        },
        {
          "griechisch": "ἡμέτερος",
          "umschrift": "hēméteros",
          "deutsch": "unser",
          "sprich": "hähméteros",
          "audio": "data/audio/erw1_01_49.m4a"
        },
        {
          "griechisch": "κρείσσων",
          "umschrift": "kreíssōn",
          "deutsch": "stärker, mächtiger, besser",
          "sprich": "kreissohn",
          "audio": "data/audio/erw1_01_50.m4a"
        },
        {
          "griechisch": "παρακαλέω",
          "umschrift": "parakaléō",
          "deutsch": "herbeirufen; ermahnen, auffordern",
