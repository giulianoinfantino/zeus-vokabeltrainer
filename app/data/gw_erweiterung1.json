{
  "id": "erw1",
  "gruppe": "Aufbauwortschatz",
  "lektionen": [
    {
      "titel": "Aufbauwortschatz I",
      "vokabeln": [
        {
          "griechisch": "ἀπαντάω",
          "umschrift": "apantáō",
          "deutsch": "begegnen",
          "sprich": "apantáoh",
          "audio": "data/audio/erw1_00_00.m4a"
        },
        {
          "griechisch": "ἀπατάω",
          "umschrift": "apatáō",
          "deutsch": "täuschen",
          "sprich": "apatáoh",
          "audio": "data/audio/erw1_00_01.m4a"
        },
        {
          "griechisch": "ἀρέσκω",
          "umschrift": "aréskō",
          "deutsch": "gefallen",
          "sprich": "aréskoh",
          "audio": "data/audio/erw1_00_02.m4a"
        },
        {
          "griechisch": "βαδίζω",
          "umschrift": "badízō",
          "deutsch": "gehen, schreiten",
          "sprich": "badízoh",
          "audio": "data/audio/erw1_00_03.m4a"
        },
        {
          "griechisch": "θηρεύω",
          "umschrift": "thēreúō",
          "deutsch": "jagen",
          "sprich": "tähreuoh",
          "audio": "data/audio/erw1_00_04.m4a"
        },
        {
          "griechisch": "τιμωρέω",
          "umschrift": "timōréō",
          "deutsch": "rächen, strafen",
          "sprich": "timohréoh",
          "audio": "data/audio/erw1_00_05.m4a"
        },
        {
          "griechisch": "ἀσφαλής",
          "umschrift": "asphalḗs",
          "deutsch": "sicher, fest",
          "sprich": "asfalähs",
          "audio": "data/audio/erw1_00_06.m4a"
        },
        {
          "griechisch": "ταχέως",
          "umschrift": "tachéōs",
          "deutsch": "schnell",
          "sprich": "tachéohs",
          "audio": "data/audio/erw1_00_07.m4a"
        }
      ]
    },
    {
      "titel": "Aufbauwortschatz II — Hochfrequent",
      "vokabeln": [
        {
          "griechisch": "οὐδέ",
          "umschrift": "oudé",
          "deutsch": "und nicht, auch nicht; nicht einmal",
          "sprich": "udé",
          "audio": "data/audio/erw1_01_00.m4a"
        },
        {
          "griechisch": "τοιοῦτος",
          "umschrift": "toioûtos",
          "deutsch": "ein solcher, derartig",
          "sprich": "toiuhtos",
          "audio": "data/audio/erw1_01_01.m4a"
        },
        {
          "griechisch": "ὅσος",
          "umschrift": "hósos",
          "deutsch": "so groß/so viel wie; wie viel",
          "sprich": "hósos",
          "audio": "data/audio/erw1_01_02.m4a"
        },
        {
          "griechisch": "πράσσω",
          "umschrift": "prássō",
          "deutsch": "tun, handeln; (Geld) eintreiben",
          "sprich": "prássoh",
          "audio": "data/audio/erw1_01_03.m4a"
        },
        {
          "griechisch": "μηδέ",
          "umschrift": "mēdé",
          "deutsch": "und nicht, auch nicht (verneint)",
          "sprich": "mähdé",
          "audio": "data/audio/erw1_01_04.m4a"
        },
        {
          "griechisch": "ἅμα",
          "umschrift": "háma",
          "deutsch": "zugleich, zusammen (mit +Dat.)",
          "sprich": "háma",
          "audio": "data/audio/erw1_01_05.m4a"
        },
        {
          "griechisch": "τοσοῦτος",
          "umschrift": "tosoûtos",
          "deutsch": "so groß, so viel",
          "sprich": "tosuhtos",
          "audio": "data/audio/erw1_01_06.m4a"
        },
        {
          "griechisch": "μήτε",
          "umschrift": "mḗte",
          "deutsch": "und nicht; μήτε…μήτε weder…noch",
          "sprich": "mähte",
          "audio": "data/audio/erw1_01_07.m4a"
        },
        {
          "griechisch": "ποτέ",
          "umschrift": "poté",
          "deutsch": "einmal, irgendwann; je",
          "sprich": "poté",
          "audio": "data/audio/erw1_01_08.m4a"
        },
        {
          "griechisch": "ὅταν",
          "umschrift": "hótan",
          "deutsch": "wann immer, sobald (+Konj.)",
          "sprich": "hótan",
          "audio": "data/audio/erw1_01_09.m4a"
        },
        {
          "griechisch": "ἡ θάλασσα",
          "umschrift": "hē thálassa",
          "deutsch": "Meer, See",
          "sprich": "hä tálassa",
          "audio": "data/audio/erw1_01_10.m4a"
        },
        {
          "griechisch": "συμβαίνω",
          "umschrift": "symbaínō",
          "deutsch": "zusammentreffen; geschehen, sich ereignen",
          "sprich": "sümbainoh",
          "audio": "data/audio/erw1_01_11.m4a"
        },
        {
          "griechisch": "τὸ χρῆμα",
          "umschrift": "to chrêma",
          "deutsch": "Sache; Pl. Geld, Güter",
          "sprich": "to chrähma",
          "audio": "data/audio/erw1_01_12.m4a"
        },
        {
          "griechisch": "πλεῖστος",
          "umschrift": "pleîstos",
          "deutsch": "der meiste, größte",
          "sprich": "pleistos",
          "audio": "data/audio/erw1_01_13.m4a"
        },
        {
          "griechisch": "εἶτα",
          "umschrift": "eîta",
          "deutsch": "dann, darauf, hierauf",
          "sprich": "eita",
          "audio": "data/audio/erw1_01_14.m4a"
        },
        {
          "griechisch": "ἐμός",
          "umschrift": "emós",
          "deutsch": "mein",
          "sprich": "emós",
          "audio": "data/audio/erw1_01_15.m4a"
        },
        {
          "griechisch": "ἵστημι",
          "umschrift": "hístēmi",
          "deutsch": "stellen; (intr.) (sich) stellen, stehen",
          "sprich": "hístähmi",
          "audio": "data/audio/erw1_01_16.m4a"
        },
        {
          "griechisch": "ἐρῶ",
          "umschrift": "erô",
          "deutsch": "ich werde sagen (Fut. zu λέγω)",
          "sprich": "eroh",
          "audio": "data/audio/erw1_01_17.m4a"
        },
        {
          "griechisch": "ἔπειτα",
          "umschrift": "épeita",
          "deutsch": "darauf, dann, hierauf",
          "sprich": "épeita",
          "audio": "data/audio/erw1_01_18.m4a"
        },
        {
          "griechisch": "ἀμφότερος",
          "umschrift": "amphóteros",
          "deutsch": "beide(s)",
          "sprich": "amfóteros",
          "audio": "data/audio/erw1_01_19.m4a"
        },
        {
          "griechisch": "ἐνταῦθα",
          "umschrift": "entaûtha",
          "deutsch": "hier, dort; da, dann",
          "sprich": "entauta",
          "audio": "data/audio/erw1_01_20.m4a"
        },
        {
          "griechisch": "σός",
          "umschrift": "sós",
          "deutsch": "dein",
          "sprich": "sós",
          "audio": "data/audio/erw1_01_21.m4a"
        },
        {
          "griechisch": "φυλάσσω",
          "umschrift": "phylássō",
          "deutsch": "bewachen, hüten; sich hüten",
          "sprich": "fülássoh",
          "audio": "data/audio/erw1_01_22.m4a"
        },
        {
