          "umschrift": "beltíōn",
          "deutsch": "besser",
          "sprich": "beltíohn",
          "audio": "data/audio/erw1_01_60.m4a"
        },
        {
          "griechisch": "ἀπολείπω",
          "umschrift": "apoleípō",
          "deutsch": "zurücklassen, übriglassen; verlassen",
          "sprich": "apoleipoh",
          "audio": "data/audio/erw1_01_61.m4a"
        },
        {
          "griechisch": "παρέρχομαι",
          "umschrift": "parérchomai",
          "deutsch": "vorübergehen; auftreten, vortreten",
          "sprich": "parérchomai",
          "audio": "data/audio/erw1_01_62.m4a"
        },
        {
          "griechisch": "πλησίος",
          "umschrift": "plēsíos",
          "deutsch": "nahe, benachbart",
          "sprich": "plähsíos",
          "audio": "data/audio/erw1_01_63.m4a"
        },
        {
          "griechisch": "ὁπόσος",
