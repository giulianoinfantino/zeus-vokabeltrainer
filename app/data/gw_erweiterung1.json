          "deutsch": "wie viel/groß auch immer",
          "sprich": "hopósos",
          "audio": "data/audio/erw1_01_64.m4a"
        },
        {
          "griechisch": "παραγίγνομαι",
          "umschrift": "paragígnomai",
          "deutsch": "dazukommen, erscheinen, beistehen",
          "sprich": "paragígnomai",
          "audio": "data/audio/erw1_01_65.m4a"
        },
        {
          "griechisch": "τάσσω",
          "umschrift": "tássō",
          "deutsch": "ordnen, aufstellen, anordnen",
          "sprich": "tássoh",
          "audio": "data/audio/erw1_01_66.m4a"
        },
        {
          "griechisch": "ἀπαλλάσσω",
          "umschrift": "apallássō",
          "deutsch": "befreien, entfernen; (Med.) weggehen",
          "sprich": "apallássoh",
          "audio": "data/audio/erw1_01_67.m4a"
        },
        {
          "griechisch": "εἴκοσι",
          "umschrift": "eíkosi",
          "deutsch": "zwanzig",
          "sprich": "eikosi",
          "audio": "data/audio/erw1_01_68.m4a"
        },
        {
          "griechisch": "χρύσεος",
          "umschrift": "chrýseos",
          "deutsch": "golden, aus Gold",
          "sprich": "chrüseos",
          "audio": "data/audio/erw1_01_69.m4a"
        },
        {
          "griechisch": "ἅπτω",
          "umschrift": "háptō",
          "deutsch": "anzünden; (Med.) anfassen, berühren (+Gen.)",
          "sprich": "háptoh",
          "audio": "data/audio/erw1_01_70.m4a"
        },
        {
          "griechisch": "πού",
          "umschrift": "poú",
          "deutsch": "irgendwo; etwa, wohl",
          "sprich": "pú",
          "audio": "data/audio/erw1_01_71.m4a"
        },
        {
          "griechisch": "ἐμαυτοῦ",
          "umschrift": "emautoû",
          "deutsch": "meiner selbst (Reflexiv)",
          "sprich": "emautuh",
          "audio": "data/audio/erw1_01_72.m4a"
        }
      ]
    }
  ]
}
