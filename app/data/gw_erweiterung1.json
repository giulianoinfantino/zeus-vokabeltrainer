          "umschrift": "ho présbys",
          "deutsch": "alter Mann, Greis; Pl. Gesandte",
          "sprich": "ho présbüs",
          "audio": "data/audio/erw1_01_57.m4a"
        },
        {
          "griechisch": "ἔξεστι",
          "umschrift": "éxesti",
          "deutsch": "es ist erlaubt, es ist möglich",
          "sprich": "éxesti",
          "audio": "data/audio/erw1_01_58.m4a"
        },
        {
          "griechisch": "συνάγω",
          "umschrift": "synágō",
          "deutsch": "zusammenbringen, versammeln",
          "sprich": "sünágoh",
          "audio": "data/audio/erw1_01_59.m4a"
        },
        {
