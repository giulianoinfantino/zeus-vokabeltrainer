          "deutsch": "fragen, sich erkundigen",
          "sprich": "éromai",
          "audio": "data/audio/erw1_01_52.m4a"
        },
        {
          "griechisch": "λείπω",
          "umschrift": "leípō",
          "deutsch": "(zurück)lassen, verlassen",
          "sprich": "leipoh",
          "audio": "data/audio/erw1_01_53.m4a"
        },
        {
          "griechisch": "ἀποδείκνυμι",
          "umschrift": "apodeíknymi",
          "deutsch": "aufzeigen, ernennen, beweisen",
          "sprich": "apodeiknümi",
          "audio": "data/audio/erw1_01_54.m4a"
        },
        {
          "griechisch": "ἔνιοι",
          "umschrift": "énioi",
          "deutsch": "einige, manche",
          "sprich": "énioi",
          "audio": "data/audio/erw1_01_55.m4a"
        },
        {
          "griechisch": "πεζός",
          "umschrift": "pezós",
          "deutsch": "zu Fuß; Fußsoldat, Landheer",
          "sprich": "pezós",
          "audio": "data/audio/erw1_01_56.m4a"
        },
        {
